From: <you>
Subject: [PATCH] synchronized output (DEC private mode 2026)

Implements the modern synchronized-update protocol (DECSET/DECRST 2026)
plus the DECRQM query reply, so TUIs such as Textual/Rich detect support
and wrap full-screen repaints in a batch -- eliminating tearing/flicker
on cover art, visualizers, etc. (Your tree already has the min/maxlatency
draw-timing half of the old "sync" patch; this adds the mode-2026 half it
lacks, which is what `CSI ? 2026 $ p` was probing for.)

  - st.c: `int su` flag; handle `CSI ? 2026 h/l` in tsetmode(); answer
          `CSI ? 2026 $ p` (DECRQM) with DECRPM in csihandle().
  - st.h: expose `su` to the draw loop.
  - x.c : while a batch is open, keep parsing input but defer draw() until
          the app closes the batch (su clears) or a 1000 ms safety timeout
          elapses, so a crashed app cannot freeze the screen.

Tested-by: applies cleanly; needs a local build to verify at runtime.
---
--- a/st.c
+++ b/st.c
@@ -275,6 +275,10 @@
 static int iofd = 1;
 static int cmdfd;
 static pid_t pid;
+
+/* Synchronized output (DEC private mode 2026): nonzero while an application
+ * has an update batch open. The draw loop in x.c reads this to defer drawing. */
+int su = 0;
 
 static const uchar utfbyte[UTF_SIZ + 1] = {0x80,    0, 0xC0, 0xE0, 0xF0};
 static const uchar utfmask[UTF_SIZ + 1] = {0xC0, 0x80, 0xE0, 0xF0, 0xF8};
@@ -1977,6 +1981,9 @@
 			case 2004: /* 2004: bracketed paste mode */
 				xsetmode(set, MODE_BRCKTPASTE);
 				break;
+			case 2026: /* synchronized output: begin/end update batch */
+				su = set;
+				break;
 			/* Not implemented mouse modes. See comments there. */
 			case 1001: /* mouse highlight mode; can hang the
 				      terminal by design when implemented. */
@@ -2240,6 +2247,17 @@
 			goto unknown;
 		} else {
 			tcursor(CURSOR_LOAD);
+		}
+		break;
+	case '$': /* DECRQM -- Request DEC private mode */
+		if (csiescseq.priv && csiescseq.mode[1] == 'p') {
+			int md = csiescseq.arg[0];
+			/* DECRPM value: 0=not recognised, 1=set, 2=reset */
+			int v = (md == 2026) ? (su ? 1 : 2) : 0;
+			len = snprintf(buf, sizeof(buf), "\033[?%d;%d$y", md, v);
+			ttywrite(buf, len, 0);
+		} else {
+			goto unknown;
 		}
 		break;
 	case ' ':
--- a/st.h
+++ b/st.h
@@ -142,6 +142,7 @@
 extern wchar_t *worddelimiters;
 extern int allowaltscreen;
 extern int allowwindowops;
+extern int su;
 extern char *termname;
 extern unsigned int tabspaces;
 extern unsigned int defaultfg;
--- a/x.c
+++ b/x.c
@@ -2333,6 +2333,12 @@
 	int xfd = XConnectionNumber(xw.dpy), ttyfd, xev, drawing;
 	struct timespec seltv, *tv, now, lastblink, trigger;
 	double timeout;
+	/* Synchronized output (DEC mode 2026): when an app opens an update
+	 * batch we hold drawing until it closes the batch or this many ms
+	 * elapse, so a crashed app can't freeze the screen indefinitely. */
+	static const double sutimeout = 1000.0;
+	struct timespec sustart = {0};
+	int suprev = 0;
 
 	/* Waiting for window mapping */
 	do {
@@ -2412,6 +2418,21 @@
 			          / maxlatency * minlatency;
 			if (timeout > 0)
 				continue;  /* we have time, try to find idle */
+		}
+
+		/*
+		 * Synchronized output (DEC mode 2026): while an update batch is
+		 * open, keep reading/parsing but hold off drawing so the screen
+		 * never shows a half-applied frame. Draw on batch end (su clears,
+		 * handled below by falling through) or when the safety timeout
+		 * expires. sustart is armed on the rising edge of su.
+		 */
+		if (su && !suprev)
+			sustart = now;
+		suprev = su;
+		if (su && TIMEDIFF(now, sustart) < sutimeout) {
+			timeout = sutimeout - TIMEDIFF(now, sustart);
+			continue;
 		}
 
 		/* idle detected or maxlatency exhausted -> draw */
