+/* Apply the configured alpha to the default background color: the XRender
+ * color (used for cell backgrounds) and the packed pixel value (used for the
+ * X11 window background/border). Keeping both in sync here avoids drift. */
+static void
+setdefaultbgalpha(void)
+{
+	dc.col[defaultbg].color.alpha = (unsigned short)(0xffff * alpha);
+	dc.col[defaultbg].pixel &= 0x00FFFFFF;
+	dc.col[defaultbg].pixel |= (unsigned char)(0xff * alpha) << 24;
+}
+
 void
 xloadcols(void)
 {
