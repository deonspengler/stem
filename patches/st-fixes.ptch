 	return 0;
@@ -1563,9 +1570,12 @@
 	if (alpha > 1.0f)
 		alpha = 1.0f;
 
-	dc.col[defaultbg].color.alpha = (unsigned short)(0xFFFF * alpha);
-	/* Required to remove artifacting from borderpx */
-	cresize(0, 0);
+	setdefaultbgalpha();
+	/* Refresh the window's own background so the internal borderpx region
+	 * and any exposed area use the new alpha. Do NOT touch the window
+	 * border: it is owned by the WM (e.g. bspwm), and overwriting it makes
+	 * the WM border color disappear. */
+	XSetWindowBackground(xw.dpy, xw.win, dc.col[defaultbg].pixel);
 	redraw();
 }
 
@@ -1573,8 +1583,8 @@
